{
  "name": "hassio-1password-addon",
  "version": "0.3.0",
  "private": true,
  "description": "1Password for Home Assistant",
  "type": "module",
  "scripts": {
    "build": "next build",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "dev": "next dev -p 8000",
    "lint": "eslint .",
    "migration:dev": "prisma migrate dev",
    "migration:prod": "prisma migrate deploy",
    "prebuild": "prisma generate",
    "prettier": "prettier --check ./src ./messages",
    "prettier:fix": "prettier --write ./src ./messages",
    "prisma:generate": "prisma generate",
    "start": "next start -p 8000",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@1password/op-js": "^0.1.13",
    "@heroui/react": "^2.8.10",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "home-assistant-js-websocket": "^9.6.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "prisma-extension-pagination": "^0.7.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-syntax-highlighter": "^16.1.1",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-aria/ssr": "^3.9.10",
    "@react-aria/visually-hidden": "^3.8.31",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/coverage-v8": "^4.1.9",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-package": "^2.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
